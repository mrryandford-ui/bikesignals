<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Camera lens — concentric rings, center (44,54) -->
    <!-- Blue outer body -->
    <path
        android:fillColor="#3B82F6"
        android:pathData="M24,54 A20,20,0,1,0,64,54 A20,20,0,1,0,24,54 Z"/>
    <!-- Dark ring (creates blue outer ring) -->
    <path
        android:fillColor="#090910"
        android:pathData="M29,54 A15,15,0,1,0,59,54 A15,15,0,1,0,29,54 Z"/>
    <!-- Blue iris -->
    <path
        android:fillColor="#3B82F6"
        android:pathData="M35,54 A9,9,0,1,0,53,54 A9,9,0,1,0,35,54 Z"/>
    <!-- Dark pupil -->
    <path
        android:fillColor="#090910"
        android:pathData="M40,54 A4,4,0,1,0,48,54 A4,4,0,1,0,40,54 Z"/>
    <!-- Lens shine -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.45"
        android:pathData="M28,43 Q33,36 41,39 Q36,45 34,51 Z"/>

    <!-- Signal arcs radiating right — the "Net" in CamNet -->
    <!-- Arc 1 (nearest, r=26 from lens center) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:pathData="M67,41 A26,26,0,0,1,67,67"/>
    <!-- Arc 2 (r=31) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:pathData="M71,39 A31,31,0,0,1,71,69"/>
    <!-- Arc 3 (farthest, r=36) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:pathData="M75,36 A36,36,0,0,1,75,72"/>

</vector>
