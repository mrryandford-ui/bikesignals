<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      Localhost: cleartext HTTP required for the embedded Ktor server
      (monitor loads viewer.html via http://localhost:3000/).
      Android does support "localhost" as a domain name here.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!--
      Everything else (LAN IPs like 192.168.x.x, 10.x.x.x):
      No cleartext — camera phones always connect via HTTPS (port 3443,
      SslProxy). Self-signed cert errors are handled programmatically
      in onReceivedSslError -> isPrivateHost() check -> handler.proceed().
      User certs included so the self-signed cert can optionally be
      manually trusted via device settings too.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
